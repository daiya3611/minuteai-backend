STRIPE_SECRET_KEY=sk_test_ここにシークレットキーを貼る
STRIPE_PRICE_STANDARD=price_1TQpfu1VLRrjRjSDBoVZURN1
STRIPE_PRICE_TEAM=price_1TQpjL1VLRrjRjSDwheTSPvw
FRONTEND_URL=https://minuteai.vercel.app
PORT=3001

# === マーケット動向・ニュース監視 ===
# Slack Incoming Webhook URL (未設定ならコンソールに出力)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# Claude による要約用。未設定なら生データのプレーン整形にフォールバック
ANTHROPIC_API_KEY=sk-ant-xxxxx
# 使用するClaudeモデル (任意。既定: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# 定期実行 (任意)
# cron式。既定は平日08:00。例: 毎日朝7時 = "0 7 * * *"
CRON_SCHEDULE=0 8 * * 1-5
CRON_TZ=Asia/Tokyo
# スケジューラを止めたい場合は false
ENABLE_SCHEDULER=true

# ウォッチリストをJSONで上書き (任意。未設定なら src/config/watchlist.js の既定)
# WATCHLIST={"日本株":[{"symbol":"7203.T","name":"トヨタ"}]}
# 市場ニュースの検索クエリをカンマ区切りで上書き (任意)
# MARKET_NEWS_QUERIES=株式市場,日経平均,米国株,ビットコイン
